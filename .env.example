# SwasthAI Environment Variables Template
# Copy this file to .env and fill in the values
# Never commit .env files with secrets

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/swasthai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=swasthai

# ============================================
# AI INTEGRATIONS
# ============================================
# Anthropic Claude
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
AI_INTEGRATIONS_GEMINI_API_KEY=AIzaSy...

# OpenAI (optional)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# ============================================
# DODO PAYMENTS (Web3 Integration)
# ============================================
# Get these from: https://dashboard.dodopayments.com
DODO_API_KEY=your_dodo_api_key_here
DODO_SECRET_KEY=your_dodo_secret_key_here
DODO_API_ENV=sandbox  # sandbox or production
DODO_WEBHOOK_SECRET=your_webhook_secret_here

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com  # devnet for testing
SOLANA_NETWORK=devnet  # devnet, testnet, mainnet-beta
USDC_MINT=EPjFWaLb3oqJJPxrb5VmHeE5AacVhQQkEHbVE1MkJDDV

# ============================================
# SMS & COMMUNICATIONS
# ============================================
# Twilio SMS (optional - app works without it using demo codes)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ============================================
# SECURITY
# ============================================
# Doctor Console Passcode
DOCTOR_PASSCODE=doctor2026

# JWT Secret (if using JWT)
JWT_SECRET=your_long_random_secret_here

# ============================================
# CORS & NETWORKING
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:19002,http://localhost:5173,http://localhost:8080

# Application URLs
APP_URL=http://localhost:3000  # Frontend URL
API_URL=http://localhost:8080  # API URL

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============================================
# EXPO/APP CONFIGURATION
# ============================================
EXPO_PUBLIC_DOMAIN=localhost:19002
EXPO_PUBLIC_API_URL=http://localhost:8080

# ============================================
# STORAGE
# ============================================
# Replit Object Storage or compatible S3
STORAGE_BUCKET_NAME=default
STORAGE_REGION=us-east-1

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
NODE_ENV=development

# ============================================
# PORTS
# ============================================
PORT=8080
DOCTOR_PORT=5173
EXPO_PORT=19002
DB_PORT=5432
