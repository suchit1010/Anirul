# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# ============================================
# DEPENDENCIES - NEVER COMMIT
# ============================================
node_modules/
.pnpm-store/
pnpm-lock.yaml
package-lock.json
yarn.lock
.npm
*.tsbuildinfo

# ============================================
# BUILD OUTPUTS - NEVER COMMIT
# ============================================
dist/
build/
out-tsc
tmp/
temp/
.next/
out/
.expo/
.expo-shared/
static-build/
*.tgz

# ============================================
# ENVIRONMENT VARIABLES & SECRETS - NEVER COMMIT
# ============================================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.*.production
.secrets
secrets.json

# ============================================
# API KEYS & CREDENTIALS - NEVER COMMIT
# ============================================
*.key
*.pem
*.p8
*.p12
*.pfx
keystore.jks
credentials.json
.ssh/
ssh/
private/

# ============================================
# IDE & EDITOR SETTINGS - NEVER COMMIT
# ============================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/

# ============================================
# LOGS & DEBUGGING - NEVER COMMIT
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
testem.log
lerna-debug.log*
traces/

# ============================================
# TESTING & COVERAGE - NEVER COMMIT
# ============================================
coverage/
.nyc_output/
*.lcov
test-results/
.jest-cache/

# ============================================
# CACHE & TEMPORARY - NEVER COMMIT
# ============================================
.cache/
.turbo/
.sass-cache/
.next/
.eslintcache
.stylelintcache
connect.lock

# ============================================
# DATABASE - NEVER COMMIT
# ============================================
*.db
*.sqlite
*.sqlite3
data/
db-data/
.postgres-data/

# ============================================
# RUNTIME & TEMPORARY FILES - NEVER COMMIT
# ============================================
tmp/
temp/
*.tmp
.env.*.swp
*~
*.swp
*.swo
typings/

# ============================================
# SYSTEM & OS FILES - NEVER COMMIT
# ============================================
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride
*.suo
*.user
desktop.ini
ehthumbs.db

# ============================================
# PROJECT SPECIFIC - NEVER COMMIT
# ============================================
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ============================================
# REPLIT SPECIFIC - NEVER COMMIT
# ============================================
.cache/
.local/
.replit
replit_zip_error_log.txt

# ============================================
# DOCKER - NEVER COMMIT
# ============================================
docker-compose.override.yml
.dockerignore

# ============================================
# CI/CD - NEVER COMMIT
# ============================================
.github/workflows/secrets/

# ============================================
# VSCODE SERVER - NEVER COMMIT
# ============================================
.vscode-server/
.vscode-server-insiders/
